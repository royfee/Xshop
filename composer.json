{
    "name": "royfee/xshop",
    "description": "Multi-platform e-commerce SDK with unified API interface",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Roy Fee",
            "email": "royfee@example.com"
        }
    ],
    "require": {
        "php": "^7.4|^8.0",
        "monolog/monolog": "^2.0|^3.0",
        "guzzlehttp/guzzle": "^7.0|^6.0",
        "psr/log": "^1.1|^2.0|^3.0",
        "psr/container": "^1.0|^2.0",
        "psr/simple-cache": "^1.0|^2.0|^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0",
        "mockery/mockery": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "Royfee\\XShop\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Royfee\\XShop\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
